# Mangala Electrical Agency — Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=3000

# Email Notifications (Gmail SMTP)
# For Gmail: enable 2FA and create an "App Password" at https://myaccount.google.com/apppasswords
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_16_char_app_password

# Where to receive enquiry notifications
CONTACT_RECEIVER=owner@mangalaelectrical.com

# Admin API token (set any strong random string)
ADMIN_TOKEN=change_this_to_a_secure_random_token_123
MONGODB_URI=mongodb://localhost:27017/mangala_db  // For local development